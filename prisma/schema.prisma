generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SubscriptionPlan {
  id        String   @id @default(cuid())
  tier      String   @unique // "free", "pro", "business"
  name      String
  price     Float    @default(0)
  maxVehicles Int   @default(2)
  features  String[] // JSON array of feature strings
  stripePriceId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  planId          String
  stripeCustomerId String?
  stripeSubId     String?
  status          String    @default("active") // active, trialing, past_due, canceled
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])
}

model User {
  id            String    @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name         String?
  googleId     String?  @unique
  avatarUrl     String?
  resetToken    String?
  resetTokenExpiry DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  onboardingCompleted Boolean @default(false)
  currentOrganizationId String?

  currentOrganization  Organization?    @relation("CurrentOrganization", fields: [currentOrganizationId], references: [id])
  organizations        OrganizationMember[]
  subscription         Subscription?
  vehicles             Vehicle[]
  reminders            Reminder[]
  invitationsSent      Invitation[]     @relation("Inviter")
  transferCodesOwned   TransferCode[]   @relation("OwnerTransferCode")
  transferCodesUsed    TransferCode[]   @relation("UsedByUser")
  previouslyOwnedVehicles Vehicle[]     @relation("PreviousOwner")
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  primaryColor String  @default("#2563eb")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members     OrganizationMember[]
  vehicles    Vehicle[]
  invitations Invitation[]
  usersWithCurrent User[] @relation("CurrentOrganization")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("member")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Invitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           String    @default("customer")
  token          String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy     User        @relation("Inviter", fields: [invitedById], references: [id])
}

model Vehicle {
  id              String    @id @default(cuid())
  userId          String
  organizationId  String?
  make            String
  model           String
  year            Int
  vin             String?   @unique
  nickname       String?
  vehicleType     String    @default("car")
  status          String    @default("active")
  currentMileage Int       @default(0)
  previousOwnerId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization?        @relation(fields: [organizationId], references: [id])
  previousOwner     User?                @relation("PreviousOwner", fields: [previousOwnerId], references: [id])
  maintenanceRecords MaintenanceRecord[]
  reminders        Reminder[]
  transferCodes   TransferCode[]
}

model MaintenanceRecord {
  id         String   @id @default(cuid())
  vehicleId String
  date      DateTime
  serviceType String
  mileage   Int
  notes     String?
  imageUrl  String?
  cost      Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String    @id @default(cuid())
  vehicleId  String
  userId     String
  title      String
  description String?
  dueDate    DateTime?
  dueMileage Int?
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TransferCode {
  id            String    @id @default(cuid())
  vehicleId    String
  ownerId       String
  code         String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  usedByUserId String?
  createdAt   DateTime  @default(now())

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  owner     User    @relation("OwnerTransferCode", fields: [ownerId], references: [id])
  usedByUser User?   @relation("UsedByUser", fields: [usedByUserId], references: [id])
}

model ServiceRecommendation {
  serviceType      String  @id
  recommendedMiles Int    @default(5000)
  recommendedMonths Int   @default(6)
}
