generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SubscriptionPlan {
  id        String   @id @default(cuid())
  tier      String   @unique
  name      String
  price     Float    @default(0)
  maxVehicles Int @default(1)
  features  String[]
  stripePriceId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  planId          String
  paymentProcessor String   @default("free")  // "free" | "stripe" | "paypal"
  stripeCustomerId String?
  stripeSubId     String?
  paypalSubId     String?
  paypalPayerId   String?
  status          String    @default("active")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
  @@index([paymentProcessor])
}

model User {
  id            String    @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  name         String?
  googleId     String?  @unique
  avatarUrl     String?
  resetToken    String?
  resetTokenExpiry DateTime?
  phone         String?
  smsNotifications Boolean @default(false)
  pushNotifications Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  onboardingCompleted Boolean @default(false)
  currentOrganizationId String?

  currentOrganization  Organization?    @relation("CurrentOrganization", fields: [currentOrganizationId], references: [id])
  organizations        OrganizationMember[]
  subscription         Subscription?
  vehicles             Vehicle[]
  reminders            Reminder[]
  invitationsSent      Invitation[]     @relation("Inviter")
  transferCodesOwned   TransferCode[]   @relation("OwnerTransferCode")
  transferCodesUsed    TransferCode[]   @relation("UsedByUser")
  previouslyOwnedVehicles Vehicle[]     @relation("PreviousOwner")
  serviceReviews        ServiceReview[]

  @@index([email])
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  primaryColor String  @default("#2563eb")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members     OrganizationMember[]
  vehicles    Vehicle[]
  invitations Invitation[]
  constructionSites ConstructionSite[]
  usersWithCurrent User[] @relation("CurrentOrganization")
  drivers     Driver[]
  parts       Part[]
  serviceProviders ServiceProvider[]

  @@index([slug])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("member")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Invitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           String    @default("customer")
  token          String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy     User        @relation("Inviter", fields: [invitedById], references: [id])

  @@index([email])
  @@index([invitedById])
  @@index([token])
}

model ConstructionSite {
  id             String   @id @default(cuid())
  name           String
  address        String?
  city           String?
  state          String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicles     Vehicle[]

  @@index([organizationId])
}

model Vehicle {
  id              String    @id @default(cuid())
  userId          String
  organizationId  String?
  make            String
  model           String
  year            Int
  vin             String?   @unique
  nickname       String?
  vehicleType     String    @default("car")
  status          String    @default("active")
  currentMileage Int       @default(0)
  hoursMeter     Int?
  serialNumber   String?
  weightCapacity Float?
  equipmentStatus String?
  constructionSiteId String?
  previousOwnerId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization?        @relation(fields: [organizationId], references: [id])
  constructionSite  ConstructionSite?    @relation(fields: [constructionSiteId], references: [id])
  previousOwner     User?                @relation("PreviousOwner", fields: [previousOwnerId], references: [id])
  maintenanceRecords MaintenanceRecord[]
  reminders        Reminder[]
  transferCodes   TransferCode[]
  documents        VehicleDocument[]
  assignments      VehicleAssignment[]
  parts            Part[]

  @@index([userId])
  @@index([organizationId])
  @@index([constructionSiteId])
  @@index([previousOwnerId])
  @@index([vin])
}

model MaintenanceRecord {
  id         String   @id @default(cuid())
  vehicleId String
  date      DateTime
  serviceType String
  mileage   Int
  notes     String?
  imageUrl  String?
  cost      Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([date])
}

model Reminder {
  id          String    @id @default(cuid())
  vehicleId  String
  userId     String
  title      String
  description String?
  dueDate    DateTime?
  dueMileage Int?
  dueHours   Int?
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([userId])
  @@index([isCompleted])
}

model TransferCode {
  id            String    @id @default(cuid())
  vehicleId    String
  ownerId       String
  code         String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  usedByUserId String?
  createdAt   DateTime  @default(now())

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  owner     User    @relation("OwnerTransferCode", fields: [ownerId], references: [id])
  usedByUser User?   @relation("UsedByUser", fields: [usedByUserId], references: [id])

  @@index([vehicleId])
  @@index([ownerId])
  @@index([code])
}

model VehicleDocument {
  id        String   @id @default(cuid())
  vehicleId String
  name      String
  type      String   @default("other")
  fileUrl   String
  fileSize  Int?
  expiryDate DateTime?
  notes     String?
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([expiryDate])
}

model Driver {
  id              String   @id @default(cuid())
  organizationId  String
  name            String
  email           String?
  phone           String?
  licenseNumber   String?
  licenseExpiry   DateTime?
  licenseState    String?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments  VehicleAssignment[]

  @@index([organizationId])
  @@index([email])
}

model VehicleAssignment {
  id         String   @id @default(cuid())
  vehicleId  String
  driverId   String
  startDate  DateTime @default(now())
  endDate    DateTime?
  isPrimary  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([driverId])
}

model Part {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  partNumber     String?
  category       String   @default("other")
  quantity       Int      @default(0)
  minStock       Int      @default(0)
  unitCost       Float?
  supplier       String?
  notes          String?
  vehicleId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  vehicle      Vehicle?      @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([vehicleId])
  @@index([category])
}

model ServiceProvider {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  category       String   @default("general")
  address        String?
  phone          String?
  website        String?
  email          String?
  notes          String?
  isPreferred    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  reviews      ServiceReview[]

  @@index([organizationId])
  @@index([category])
}

model ServiceReview {
  id         String   @id @default(cuid())
  providerId String
  userId     String
  rating     Int
  review     String?
  createdAt  DateTime @default(now())

  provider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([userId])
}

model ServiceRecommendation {
  serviceType      String  @id
  recommendedMiles Int    @default(5000)
  recommendedMonths Int   @default(6)
}
