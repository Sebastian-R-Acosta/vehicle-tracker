# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vehicle_tracker"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# Resend (email)
RESEND_API_KEY=""
FROM_EMAIL_ADDRESS=""

# Stripe (legacy — existing subscriptions only)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_BUSINESS_PRICE_ID=""

# PayPal (new subscriptions)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_ENVIRONMENT="sandbox"         # "sandbox" | "live"
PAYPAL_PRO_PLAN_ID=""
PAYPAL_BUSINESS_PLAN_ID=""
PAYPAL_WEBHOOK_ID=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Twilio (SMS notifications - optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Vercel KV (rate limiting persistence)
KV_URL=""
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# Cron
CRON_SECRET="your-cron-secret-here"

# To set up the cron job for document expiry tracking and reminders:
# Vercel Cron Jobs: Add a cron job in vercel.json pointing to /api/cron/notifications
# External (e.g. cron-job.org): GET https://your-domain.com/api/cron/notifications
#   with header: Authorization: Bearer YOUR_CRON_SECRET
# Recommended schedule: daily ("0 8 * * *" or every 24 hours)